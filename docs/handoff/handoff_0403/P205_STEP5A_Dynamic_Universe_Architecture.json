  "architecture": {
    "layers": ["candidate_pool", "feature_provider", "selector_ranking"],

    "candidate_pool": {
      "description": "후보군 원천을 정의하는 계층",
      "supported_modes": [
        {
          "mode": "fixed_current",
          "type": "static",
          "v1_status": "legacy_compat",
          "description": "기존 12종목 정적 리스트"
        },
        {
          "mode": "expanded_candidates",
          "type": "static",
          "v1_status": "legacy_compat",
          "description": "기존 33종목 정적 리스트"
        },
        {
          "mode": "dynamic_etf_market",
          "type": "dynamic",
          "v1_status": "new_target",
          "description": "KRX ETF 시장에서 동적 선별"
        }
      ],
      "v1_scope": "ETF only (개별주 미포함)",
      "config_schema": {
        "mode": "dynamic_etf_market",
        "source": "krx_etf_list",
        "filters": {
          "min_listing_days": 180,
          "min_avg_volume_20d": 50000,
          "min_nav": 1000,
          "exclude_leveraged": false,
          "exclude_inverse": true,
          "exclude_synthetic": true,
          "asset_class_whitelist": ["equity", "bond", "commodity", "mixed"]
        },
        "refresh_frequency": "weekly",
        "max_candidates": 200
      }
    },

    "feature_provider": {
      "description": "후보별 스코어링 feature를 공급하는 Registry 기반 확장형 계층",
      "schema_type": "extensible_list",
      "feature_object_schema": {
        "key": "string — feature 고유 식별자",
        "source": "string — 데이터 출처 (ohlcv / external_api / derived)",
        "enabled": "boolean — 현재 활성화 여부",
        "required": "boolean — 누락 시 후보 제외 여부",
        "weight": "float — 최종 점수 계산 시 가중치",
        "lookback": "int — 과거 영업일 수",
        "lag_days": "int — 데이터 지연 허용일",
        "freshness_ttl": "string — 데이터 유효 기간",
        "missing_policy": "string — exclude / fill_zero / fill_median / skip_scoring",
        "normalization": "string — z_score / min_max / percentile_rank / none",
        "notes": "string — 한국어 설명"
      },

      "v1_active_features": [
        {
          "key": "price_momentum_3m",
          "source": "ohlcv",
          "enabled": true,
          "required": false,
          "weight": 0.30,
          "lookback": 60,

          "notes": "3개월 가격 모멘텀 (종가 기준 수익률)"
        },
        {
          "key": "price_momentum_6m",
          "source": "ohlcv",
          "enabled": true,
          "required": false,
          "weight": 0.20,
          "lookback": 120,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "exclude",
          "normalization": "percentile_rank",
          "notes": "6개월 가격 모멘텀 (종가 기준 수익률)"
        },
        {
          "key": "volatility_20d",
          "source": "ohlcv",
          "enabled": true,
          "required": false,
          "weight": 0.15,
          "lookback": 20,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "exclude",
          "normalization": "z_score",
          "notes": "20일 변동성 (낮을수록 좋음, 역방향 적용)"
        },
        {
          "key": "liquidity_20d",
          "source": "ohlcv",
          "enabled": true,
          "required": false,
          "weight": 0.15,
          "lookback": 20,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "exclude",
          "normalization": "percentile_rank",
          "notes": "20일 평균 거래대금"
        },
        {
          "key": "turnover_rate",
          "source": "ohlcv",
          "enabled": true,
          "required": false,
          "weight": 0.10,
          "lookback": 20,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "fill_zero",
          "normalization": "percentile_rank",
          "notes": "회전율"
        },
        {
          "key": "drawdown_from_high",
          "source": "ohlcv",
          "enabled": true,
          "required": false,
          "weight": 0.10,
          "lookback": 60,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "exclude",
          "normalization": "min_max",
          "notes": "고점 대비 낙폭 (낮을수록 좋음, 역방향 적용)"
        }
      ],

      "v2_disabled_slots": [
        {
          "key": "news_sentiment",
          "source": "external_api",
          "enabled": false,
          "required": false,
          "weight": 0.0,
          "lookback": 7,
          "lag_days": 1,
          "freshness_ttl": "1d",
          "missing_policy": "skip_scoring",
          "normalization": "z_score",
          "notes": "[V2 슬롯] 뉴스 감성 점수. 데이터 품질 미검증, API 비용 리스크.",
          "disabled_reason": "데이터 품질 미검증, API 비용, 지연 리스크"
        },
        {
          "key": "fear_index",
          "source": "external_api",
          "enabled": false,
          "required": false,
          "weight": 0.0,
          "lookback": 1,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "skip_scoring",
          "normalization": "min_max",
          "notes": "[V2 슬롯] VIX/VKOSPI 기반 공포지수.",
          "disabled_reason": "VIX/VKOSPI 데이터 수급 안정성 미확인"
        },
        {
          "key": "market_breadth",
          "source": "derived",
          "enabled": false,
          "required": false,
          "weight": 0.0,
          "lookback": 20,
          "lag_days": 0,
          "freshness_ttl": "1d",
          "missing_policy": "skip_scoring",
          "normalization": "percentile_rank",
          "notes": "[V2 슬롯] 시장 폭 지표 (상승 종목 비율 등).",
          "disabled_reason": "계산 로직 정의 및 백테스트 검증 필요"
        },
        {
          "key": "macro_regime",
          "source": "external_api",
          "enabled": false,
          "required": false,
          "weight": 0.0,
          "lookback": 60,
          "lag_days": 1,
          "freshness_ttl": "7d",
          "missing_policy": "skip_scoring",
          "normalization": "none",
          "notes": "[V2 슬롯] 매크로 레짐 분류 (확장/수축/전환).",
          "disabled_reason": "레짐 분류 모델 설계/검증 선행 필요"
        }
      ],

      "disabled_slot_policy": "구조상 수용 가능하지만 동시 활성화 시 원인 분리 어렵고 데이터 품질 리스크가 크므로 V1에서는 핵심 성능을 먼저 검증한다."
    },

    "selector_ranking": {
      "description": "Feature matrix를 받아 최종 유니버스를 선별하는 계층",
      "pipeline": [
        "raw_candidates",
        "pre_filters",
        "hard_exclusions",
        "feature_scoring",
        "ranking",
        "top_n_selection",
        "tie_breaker",
        "fallback_rule"
      ],
      "config_schema": {
        "pre_filters": [
          {"field": "avg_volume_20d", "op": ">=", "value": 100000},
          {"field": "listing_days", "op": ">=", "value": 180},
          {"field": "price", "op": ">=", "value": 1000}
        ],
        "hard_exclusions": [
          {"field": "is_inverse", "op": "==", "value": true},
          {"field": "is_suspended", "op": "==", "value": true},
          {"field": "daily_limit_hit_5d", "op": ">", "value": 0}
        ],
        "ranking_formula": "weighted_sum",
        "top_n": 15,
        "tie_breaker": "liquidity_20d",
        "fallback_rule": {
          "min_candidates": 5,
          "action": "relax_pre_filters",
          "relaxation_order": ["min_avg_volume_20d", "min_listing_days"]
        }
      }
    }
  },

  "evidence_outputs": {
    "universe_snapshot": {
      "path": "reports/tuning/universe_snapshot_latest.json",
      "description": "스캐너 실행 결과 스냅샷",
      "fields": [
        "asof", "scanner_mode", "scanner_version",
        "candidate_pool_size", "pre_filter_passed",
        "hard_exclusion_removed", "scoring_eligible",
        "selected_top_n", "selected_tickers",
        "excluded_tickers_with_reasons",
        "feature_weights_used", "disabled_features"
      ]
    },
    "feature_matrix": {
      "path": "reports/tuning/universe_feature_matrix_latest.csv",
      "description": "후보별 feature 값 테이블",
      "columns": [
        "ticker", "name",
        "price_momentum_3m", "price_momentum_6m",
        "volatility_20d", "liquidity_20d",
        "turnover_rate", "drawdown_from_high",
        "composite_score", "rank", "selected"
      ]
    },
    "selection_reason": {
      "path": "reports/tuning/universe_selection_reason_latest.md",
      "description": "선택 근거 한국어 요약",
      "min_content": [
        "스캐너 실행 일시 및 모드",
        "후보 풀 규모 → 필터 후 → 최종 선택 수",
        "상위 종목 선택 근거",
        "주요 제외 종목과 사유",
        "feature 활성/비활성 현황",
        "이전 스냅샷 대비 변경 사항"
      ]
    }
  },

  "validation_plan": {
    "comparison_targets": [
      {"mode": "fixed_current", "role": "baseline"},
      {"mode": "expanded_candidates", "role": "manual_expansion"},
      {"mode": "dynamic_etf_market", "role": "scanner_auto"}
    ],
    "comparison_sequence": [
      "SSOT에 universe_mode 설정",
      "Run Tune (Optuna 탐색)",
      "1등 파라미터 SSOT 반영",
      "Run Full Backtest (전체 기간 검산)",
      "승격 판정 (promotion_verdict)",
      "A/B 비교팩 갱신"
    ],
    "comparison_metrics": [
      "best_score", "cagr_full", "cagr_seg",
      "mdd_full", "mdd_seg", "sharpe_full", "sharpe_seg",
      "overfit_penalty", "worst_segment",
      "universe_size", "momentum_concentration"
    ],
    "promotion_gate_integration": {
      "used_universe_match": "스캐너 selected_tickers == SSOT universe. 불일치 시 PROMOTE_CANDIDATE 금지.",
      "used_params_match_ssot": "5축 파라미터 일치. 유니버스 선택 방식과 독립적으로 작동.",
      "scanner_result_apply_method": "수동 (사용자 승인 후 적용). 자동 적용 금지."
    }
  },


# POC1 Step 3 — 환경변수 견본.
# 실제 값은 .env (gitignore 됨) 에 채워서 사용하세요.
# 누락된 항목은 delivery 레이어에서 fail-loud (DeliveryConfigError) 로 차단됩니다.

# === Telegram (기존 Phase 1 자산. OCI 측 secrets 와 동기화 권장) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === OCI 백엔드 (Phase 1 호환 — 직접 사용은 daily_ops.sh) ===
OCI_BACKEND_URL=
OCI_OPS_TOKEN=

# === POC1 Step 3 OCI 전달 (SCP/SSH) ===
# OCI_SSH_TARGET 은 ~/.ssh/config 의 alias 또는 user@host 형식.
# 예) OCI_SSH_TARGET=oci-krx
# 또는 OCI_SSH_TARGET=ubuntu@123.45.67.89
OCI_SSH_TARGET=

# OCI 측 inbox / outbox 절대 경로 (Phase 1 레포 위치 기준)
OCI_REMOTE_INBOX=/home/ubuntu/krx_hyungsoo/state/poc1_inbox
OCI_REMOTE_OUTBOX=/home/ubuntu/krx_hyungsoo/state/poc1_outbox

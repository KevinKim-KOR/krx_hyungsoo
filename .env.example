# 환경변수 견본 — 실제 값은 .env (gitignored) 에 채워서 사용.
#
# 표준 패턴 (DEV_RULES 9철칙 #7 / #9 준수):
# - 모든 환경변수는 app.config.require_env / optional_env 를 통해서만 조회한다.
# - 필수 키 누락 시 EnvConfigError 로 fail-loud 종료.
# - 새 환경변수 도입 시 이 파일에도 반드시 변수명을 추가한다.
#
# .env 자동 로드 위치: 프로젝트 루트의 .env (app/config.py 가 처리).
# OS 환경변수가 .env 보다 우선한다 (셸 export 가 이긴다).

# === Telegram (필수, OCI consumer 가 직접 사용) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === OCI 백엔드 (Phase 1 호환 — 직접 사용은 daily_ops.sh) ===
OCI_BACKEND_URL=
OCI_OPS_TOKEN=

# === POC1 Step 3 OCI 전달 (필수) ===
# OCI_SSH_TARGET 은 ~/.ssh/config 의 alias 또는 user@host 형식.
OCI_SSH_TARGET=
OCI_REMOTE_INBOX=
OCI_REMOTE_OUTBOX=

# === POC1 Step 3 OCI SSH 키 (선택) ===
# 미설정 시 OpenSSH 기본 키 검색 (~/.ssh/id_rsa, id_ed25519 등) 사용.
# 설정 시 ssh -i <key> -o IdentitiesOnly=yes 로 동작.
OCI_SSH_KEY_PATH=
